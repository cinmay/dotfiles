[
  {
    "name": "Tmux",
    "commands": [
      {
        "name": "Create window",
        "command": "ctrl + b c"
      },
      {
        "name": "Rename current window",
        "command": "ctrl + b ,"
      },
      {
        "name": "Close current window",
        "command": "ctrl + b & "
      },
      {
        "name": "List windows ",
        "command": "ctrl + b w"
      },
      {
        "name": "Previous window",
        "command": "ctrl + b p"
      },
      {
        "name": "Next window",
        "command": "ctrl + b n"
      },
      {
        "name": "Toggle last active window",
        "command": "ctrl + b l"
      }
    ]
  },
  {
    "name": "Copilot",
    "commands": [
      {
        "name": "Accept suggestion",
        "command": "ctrl + enter"
      },
      {
        "name": "next suggestion",
        "command": "ctrl + y"
      },
      {
        "name": "previous suggestion",
        "command": "ctrl + u"
      }
    ]
  },
  {
    "name": "Vim",
    "commands": [
      {
        "name": "Toggle autosave",
        "command": ":ASToggle"
      },
      {
        "name": "Find and replace",
        "command": ":%s/old/new/g"
      },
      {
        "name": "New empty buffer",
        "command": ":enew"
      }
    ]
  },
  {
    "name": "Coding tools",
    "commands": [
      {
        "name": "Open diagnostics",
        "command": "leader + e"
      }
    ]
  },
  {
    "name": "Spell checker",
    "commands": [
      {
        "name": "Toggle spell checker",
        "command": ":setlocal spell!"
      },
      {
        "name": "Next misspelled word",
        "command": "]s"
      },
      {
        "name": "Previous misspelled word",
        "command": "[s"
      },
      {
        "name": "Correct word",
        "command": "z="
      },
      {
        "name": "Add word to dictionary",
        "command": "zg"
      },
      {
        "name": "Remove word from dictionary",
        "command": "zw"
      }
    ]
  },
  {
    "name": "kitty",
    "commands": [
      {
        "name": "Zoom out",
        "command": "ctrl + shift + +"
      },
      {
